# Claro API — copy to .env and fill in. NEVER commit .env.
# Postgres (Supabase: Dashboard → Settings → Database → Connection string, or local docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/claro

# Supabase auth (JWT verification)
SUPABASE_URL=https://dmcuwrtjtnigktqxccln.supabase.co
# HS256 legacy secret (Dashboard → Settings → API → JWT Secret). Leave empty to use JWKS (RS256/ES256).
SUPABASE_JWT_SECRET=

# Dev conveniences — NEVER enable in production
# Accepts "Authorization: Bearer dev:<phone>" without Supabase (for local/e2e testing before SMS provider is configured)
AUTH_DEV_BYPASS=true

# Optional — host invoice PDFs so WhatsApp messages can carry a tap-to-open link.
# Needs a PUBLIC Storage bucket (default name 'invoices') + the service-role key
# (Dashboard → Settings → API → service_role). Leave empty to skip hosting; the app
# then attaches the PDF via the native share sheet instead.
SUPABASE_SERVICE_ROLE_KEY=
INVOICE_BUCKET=invoices

# Bind
HOST=0.0.0.0
PORT=8000
