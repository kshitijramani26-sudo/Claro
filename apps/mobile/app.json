{
  "expo": {
    "name": "Claro",
    "slug": "claro",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "claro",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSContactsUsageDescription": "Claro suggests customers and staff from your contacts so you can bill and remind them faster."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D1150",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": ["android.permission.READ_CONTACTS"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2D1150",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Claro suggests customers and staff from your contacts so you can bill and remind them faster."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
