# Copy to .env. These are EXPO_PUBLIC_* — bundled into the app, never put secrets here.
# API base. Leave empty to auto-derive http://<metro-host-ip>:8000 (phone on same Wi-Fi).
EXPO_PUBLIC_API_BASE_URL=
# Dev auth: true = no SMS needed; any 6-digit OTP logs in as dev:<phone> (API must run AUTH_DEV_BYPASS=true).
EXPO_PUBLIC_DEV_AUTH=true
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
